{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev-full": "concurrently \"npm run dev\" \"php artisan serve\"",
        "lint": "eslint resources/js --ext .js",
        "lint:fix": "eslint resources/js --ext .js --fix",
        "format": "prettier --write resources/js/**/*.{js,json}",
        "format:check": "prettier --check resources/js/**/*.{js,json}"
    },
    "devDependencies": {
        "axios": "^1.11.0",
        "concurrently": "^9.2.1",
        "eslint": "^9.39.1",
        "laravel-vite-plugin": "^2.0.0",
        "prettier": "^3.7.4",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "sweetalert2": "^11.26.3"
    }
}
